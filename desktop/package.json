{
  "name": "codex-adapter-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Codex Adapter Electron desktop app",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "build": "npm run build --prefix .. && electron-vite build",
    "dev": "npm run build --prefix .. && electron-vite dev",
    "pack": "npm run build && electron-builder --win --dir",
    "dist": "npm run build && electron-builder --win --publish never"
  },
  "dependencies": {
    "express": "^5.2.1",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "electron": "^34.5.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}